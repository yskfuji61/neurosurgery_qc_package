{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "frontmatter_schema.json",
  "title": "Integrated Safe RAG Markdown Frontmatter Schema",
  "description": "Operator-side validation schema for required integrated Markdown frontmatter keys. This schema encodes structure and safety gates only; it is not a clinical source and contains no dosing, threshold, compatibility, repeat-dosing, TDM, facility availability, or production CDS values.",
  "type": "object",
  "required": [
    "note_type",
    "not_a_guideline",
    "not_a_prescription_order",
    "not_an_institutional_procedure",
    "not_immediate_cds_specification",
    "source_document",
    "source_section",
    "source_quote_or_summary",
    "gpt_structured_interpretation",
    "evidence_certainty",
    "recommendation_strength",
    "domestic_regulatory_status",
    "insurance_risk",
    "institutional_operability",
    "facility_candidate",
    "cds_candidate",
    "not_to_standardize",
    "undetermined_from_source",
    "external_primary_source_check_items",
    "facility_confirmation_items",
    "required_human_review",
    "ai_misread_risk",
    "rag_chunk_policy",
    "not_to_interpret_as",
    "audit_status"
  ],
  "properties": {
    "note_type": {"type": "string"},
    "not_a_guideline": {"type": "boolean", "const": true},
    "not_a_prescription_order": {"type": "boolean", "const": true},
    "not_an_institutional_procedure": {"type": "boolean", "const": true},
    "not_immediate_cds_specification": {"type": "boolean", "const": true},
    "source_document": {"type": "string"},
    "source_section": {"type": "string"},
    "source_quote_or_summary": {"type": "string"},
    "gpt_structured_interpretation": {"type": "string"},
    "evidence_certainty": {"type": "string"},
    "recommendation_strength": {"type": "string"},
    "domestic_regulatory_status": {"type": "string"},
    "insurance_risk": {"type": "string"},
    "institutional_operability": {"type": "string"},
    "facility_candidate": {"type": ["boolean", "string"]},
    "cds_candidate": {"type": ["boolean", "string"]},
    "not_to_standardize": {"type": "array", "items": {"type": "string"}},
    "undetermined_from_source": {"type": "array", "items": {"type": "string"}},
    "external_primary_source_check_items": {"type": "array", "items": {"type": "string"}},
    "facility_confirmation_items": {"type": "array", "items": {"type": "string"}},
    "required_human_review": {"type": "boolean", "const": true},
    "ai_misread_risk": {"type": "string", "enum": ["medium", "high", "very_high"]},
    "rag_chunk_policy": {"type": "string"},
    "not_to_interpret_as": {"type": "array", "items": {"type": "string"}},
    "audit_status": {"type": "string"}
  },
  "additionalProperties": true
}
